---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/common/Footer.astro';
import Header from '../components/common/Header.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Frequens Neuro Clinic - Transcranial Magnetic Stimulation">
	<main class="min-h-screen bg-white">
		<Header />

		<section id="home" class="bg-linear-to-br from-main-50 to-beige py-12 lg:py-20">
			<div class="container mx-auto px-4 max-w-7xl">
				<div class="max-w-6xl mx-auto">
					<div class="mb-8 lg:mb-12 max-w-5xl mx-auto">
						<h1 class="text-3xl text-center lg:text-4xl xl:text-5xl font-bold text-secondary mb-6">
							Transcranial Magnetic Stimulation (TMS) Clinic in Mérida
						</h1>

						<p class="text-lg lg:text-xl text-secondary-600 leading-relaxed mb-4">
							At <strong>Frequens</strong> we help children, adolescents, and adults restore emotional and cognitive well-being through
							<strong>Transcranial Magnetic Stimulation (TMS)</strong>, a safe, non-invasive technology based on modern neuroscience.
							Our approach combines <strong>technological precision</strong>, highly trained professionals, and close human support.
						</p>
					</div>

					<div class="mb-8 lg:mb-12 flex justify-center">
						<div class="relative rounded-2xl lg:rounded-3xl overflow-hidden shadow-2xl bg-secondary-100 w-full max-w-4xl">
							<video autoplay muted loop playsinline class="w-full h-auto object-cover">
								<source src="/videos/head_mesh_web.mp4" type="video/mp4" />
							</video>
						</div>
					</div>

					<div class="grid md:grid-cols-3 gap-6 lg:gap-8 max-w-6xl mx-auto mb-8">
						<div class="bg-secondary-200 p-6 rounded-xl">
							<div class="w-16 h-16 bg-main-500 rounded-full mx-auto mb-4 flex items-center justify-center">
								<Icon name="check-badge" class="w-8 h-8 text-white" />
							</div>
							<h3 class="font-semibold text-main-900 mb-2 text-center">FDA and COFEPRIS Approved</h3>
							<p class="text-sm text-secondary-600 text-center">Backed by more than 20 years of scientific research</p>
						</div>

						<div class="bg-secondary-200 p-6 rounded-xl">
							<div class="w-16 h-16 bg-main-500 rounded-full mx-auto mb-4 flex items-center justify-center">
								<Icon name="clock" class="w-8 h-8 text-white" />
							</div>
							<h3 class="font-semibold text-main-900 mb-2 text-center">Results from 20 Sessions</h3>
							<p class="text-sm text-secondary-600 text-center">Meaningful improvements within the first month</p>
						</div>

						<div class="bg-secondary-200 p-6 rounded-xl">
							<div class="w-16 h-16 bg-main-500 rounded-full mx-auto mb-4 flex items-center justify-center">
								<Icon name="heart" class="w-8 h-8 text-white" />
							</div>
							<h3 class="font-semibold text-main-900 mb-2 text-center">Non-Invasive Treatment</h3>
							<p class="text-sm text-secondary-600 text-center">No pain, no anesthesia, no downtime</p>
						</div>
					</div>

					<div class="text-center">
						<a href="https://calendly.com/frequens/sesiondeevaluacion" target="_blank" class="btn-primary inline-flex items-center gap-2">
							<Icon name="calendar" class="w-5 h-5" />
							Free Evaluation
						</a>
					</div>
				</div>
			</div>
		</section>

		<Footer />
	</main>
</Layout>
